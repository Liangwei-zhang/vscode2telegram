{
  "name": "vscode2telegram",
  "version": "1.0.0",
  "description": "Telegram bot to control VSCode and get results back",
  "main": "src/bot/index.ts",
  "type": "module",
  "scripts": {
    "dev": "npx tsx src/bot/index.ts",
    "build": "tsc",
    "start": "node dist/bot/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "grammy": "^1.19.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
