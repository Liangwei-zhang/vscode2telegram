{
  "name": "vscode2telegram",
  "version": "2.0.0",
  "description": "Telegram bot to control VSCode and execute commands with results",
  "main": "dist/bot/index.js",
  "type": "module",
  "author": "Liangwei-zhang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Liangwei-zhang/vscode2telegram.git"
  },
  "keywords": [
    "vscode",
    "telegram",
    "bot",
    "extension",
    "websocket"
  ],
  "homepage": "https://github.com/Liangwei-zhang/vscode2telegram",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npx tsx src/bot/index.ts",
    "build": "tsc",
    "start": "node dist/bot/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "grammy": "^1.19.0",
    "undici": "^7.24.6",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.57.0",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
